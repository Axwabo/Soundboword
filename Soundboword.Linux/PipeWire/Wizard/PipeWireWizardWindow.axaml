<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wizard="clr-namespace:Soundboword.Linux.PipeWire.Wizard"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
        x:Class="Soundboword.Linux.PipeWire.Wizard.PipeWireWizardWindow"
        x:DataType="wizard:PipeWireWizardWindowViewModel"
        Title="PipeWire Wizard"
        Width="600" Height="400">
    <Design.DataContext>
        <wizard:PipeWireWizardWindowViewModel />
    </Design.DataContext>
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="5">
        <Label HorizontalAlignment="Center">The wizard will:</Label>
        <Label Content="{Binding TargetDirectory, StringFormat=1. Create \{0\}}" />
        <Label Content="{Binding TargetFile, StringFormat=2. Write \{0\}}" />
        <Label>3. Run systemctl --user restart pipewire pipewire-pulse wireplumber</Label>
        <Button Command="{Binding RunCommand}" HorizontalAlignment="Center">Run</Button>
    </StackPanel>
</Window>
