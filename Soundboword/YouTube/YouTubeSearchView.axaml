<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:youTube="clr-namespace:Soundboword.YouTube"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
             x:Class="Soundboword.YouTube.YouTubeSearchView"
             x:DataType="youTube:YouTubeSearchViewModel"
             Container.Name="window" Container.Sizing="Width">
    <Design.DataContext>
        <youTube:YouTubeSearchViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <ContainerQuery Name="window" Query="max-width:300">
            <Style Selector="ListBox UniformGrid">
                <Setter Property="Columns" Value="1" />
            </Style>
        </ContainerQuery>
    </UserControl.Styles>
    <Grid RowDefinitions="Auto,*" RowSpacing="5">
        <TextBox Name="Query" Text="{Binding Query}" PlaceholderText="Search for a video, or paste a URL" PastingFromClipboard="TextBox_OnPastingFromClipboard" />
        <ProgressBar Grid.Row="1" MaxWidth="200" IsIndeterminate="True" ProgressTextFormat="Searching..." ShowProgressText="True" IsVisible="{Binding IsSearching}" />
        <ListBox Grid.Row="1" ItemsSource="{Binding Videos}" IsVisible="{Binding !IsSearching}" SelectedItem="{Binding SelectedResult}" Background="Transparent">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Image Source="{Binding Thumbnail^}" Stretch="UniformToFill" />
                        <Label FontWeight="Bold" Content="{Binding Title}" />
                        <Label>
                            <Label.Content>
                                <MultiBinding StringFormat="\{0\} \{1:hh\':\'mm\':\'ss\}">
                                    <Binding Path="Author" />
                                    <Binding Path="Duration" />
                                </MultiBinding>
                            </Label.Content>
                        </Label>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
