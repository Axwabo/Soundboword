<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Soundboword.App"
             xmlns:converters="clr-namespace:Soundboword.Converters"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />
        <Style Selector="Rectangle.loading">
            <Style.Animations>
                <Animation Duration="0:0:1" IterationCount="INFINITE" PlaybackDirection="Alternate" Easing="QuadraticEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Fill" Value="#555" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Fill" Value="#444" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Application.Styles>

    <Application.Resources>
        <converters:TriggerModeConverter x:Key="PlaybackMode" />
        <converters:SoundStateConverter x:Key="SoundState" />
        <SolidColorBrush x:Key="Playing" Color="#1100ff00" />
        <SolidColorBrush x:Key="Paused" Color="#11ffff00" />
        <SolidColorBrush x:Key="Error" Color="#11ff0000" />
    </Application.Resources>
</Application>
