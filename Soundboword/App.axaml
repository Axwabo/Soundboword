<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Soundboword.App"
             xmlns:local="using:Soundboword"
             xmlns:converters="clr-namespace:Soundboword.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <converters:TriggerModeConverter x:Key="PlaybackMode" />
        <SolidColorBrush x:Key="Playing" Color="#1100ff00" />
    </Application.Resources>
</Application>
