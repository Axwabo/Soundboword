<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:soundboword="clr-namespace:Soundboword"
             xmlns:youTube="clr-namespace:Soundboword.YouTube"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Soundboword.Controls.Thumbnail"
             x:DataType="youTube:YouTubeVideo">
    <Viewbox Stretch="Uniform">
        <Panel>
            <Rectangle Classes="loading" Width="16" Height="9" IsVisible="{Binding !Thumbnail^}" />
            <Image Source="{Binding Thumbnail^, TargetNullValue={x:Static soundboword:ImageHelper.NotFound}}" Stretch="UniformToFill" />
        </Panel>
    </Viewbox>
</UserControl>
