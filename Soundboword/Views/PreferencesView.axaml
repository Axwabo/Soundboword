<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:settings="clr-namespace:Soundboword.Settings"
             xmlns:converters="clr-namespace:Soundboword.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Soundboword.Views.PreferencesView"
             x:DataType="settings:Preferences">
    <Design.DataContext>
        <settings:Preferences />
    </Design.DataContext>
    <ScrollViewer>
        <StackPanel Spacing="5">
            <Label>Default Trigger Mode:</Label>
            <ComboBox SelectedItem="{Binding Path=DefaultTriggerMode}" ItemsSource="{x:Static converters:TriggerModeConverter.PlaybackModes}"
                      DisplayMemberBinding="{Binding Converter={StaticResource PlaybackMode}}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
