<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Soundboword.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Soundboword.Views.SoundPlaybackView"
             x:DataType="models:SoundPlayback">
    <StackPanel Orientation="Vertical" Spacing="3">
        <TextBlock Name="SoundName" />
        <ProgressBar Foreground="Red" Name="Progress" />
        <Button Click="Button_OnClick">Stop</Button>
    </StackPanel>
</UserControl>
