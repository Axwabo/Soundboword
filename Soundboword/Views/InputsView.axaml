<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Soundboword.ViewModels"
             xmlns:models="clr-namespace:Soundboword.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Soundboword.Views.InputsView"
             x:DataType="viewModels:InputsViewModel">
    <Design.DataContext>
        <viewModels:InputsViewModel>
            <viewModels:InputsViewModel.Available>
                <models:InputMethodInterface></models:InputMethodInterface>
            </viewModels:InputsViewModel.Available>
            <viewModels:InputsViewModel.Unavailable>
                <models:InputMethodInterface></models:InputMethodInterface>
            </viewModels:InputsViewModel.Unavailable>
        </viewModels:InputsViewModel>
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="Label">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Styles>
    <Grid ColumnDefinitions="*,10,*" RowDefinitions="Auto,Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="5">
            <Label>Available Input Devices</Label>
            <Button Command="{Binding RefreshCommand}" ToolTip.Tip="Refresh Devices">🔄</Button>
        </StackPanel>
        <Rectangle Grid.Row="0" Grid.Column="1" Grid.RowSpan="3" HorizontalAlignment="Center" Width="2" Fill="DimGray" />
        <Label Grid.Row="0" Grid.Column="2">Unavailable Devices</Label>
        <ItemsControl Grid.Row="1" Grid.Column="0" ItemsSource="{Binding Available}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:InputMethodInterface">
                    <ToggleSwitch IsChecked="{Binding Activated}" OnContent="{Binding Name}" OffContent="{Binding Name}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <ItemsControl Grid.Row="1" Grid.Column="2" ItemsSource="{Binding Unavailable}" DisplayMemberBinding="{Binding Name}" Foreground="Gray" />
    </Grid>
</UserControl>
