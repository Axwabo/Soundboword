<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Soundboword.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Soundboword.Views.AddFromYouTubeWindow"
        x:DataType="viewModels:AddFromYouTubeViewModel"
        Title="AddFromYouTubeWindow">
    <StackPanel Spacing="3">
        <TextBox Text="{Binding SearchQuery}" />
        <Button Command="{Binding DownloadCommand}" IsEnabled="{Binding IsValid}">Download</Button>
        <Button Command="{Binding CancelCommand}">Cancel</Button>
        <ProgressBar IsIndeterminate="{Binding IsIndeterminate}" Value="{Binding Progress}" Maximum="1" ShowProgressText="True" />
    </StackPanel>
</Window>
