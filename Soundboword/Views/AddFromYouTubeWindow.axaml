<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:Soundboword.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
        x:Class="Soundboword.Views.AddFromYouTubeWindow"
        x:DataType="viewModels:AddFromYouTubeViewModel"
        Title="Add Sowond from YouTube">
    <Design.DataContext>
        <viewModels:AddFromYouTubeViewModel />
    </Design.DataContext>
    <Panel Margin="3">
        <UserControl Content="{Binding Search}" IsVisible="{Binding !Video.Video}" />
        <UserControl Content="{Binding Video}" IsVisible="{Binding !!Video.Video}" />
    </Panel>
</Window>
